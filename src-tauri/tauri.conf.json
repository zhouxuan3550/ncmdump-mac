{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NCM 转换器",
  "version": "1.0.0",
  "identifier": "com.ncmdump.mac",
  "build": {
    "beforeDevCommand": "npm run prepare:sidecar && npm run dev",
    "beforeBuildCommand": "npm run prepare:sidecar && npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 940,
        "height": 680,
        "minWidth": 820,
        "minHeight": 560,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 22,
          "y": 14
        },
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/ncmdump"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music"
  }
}
