{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the ncmdump desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:webview:default",
    "core:app:default",
    "dialog:default",
    "dialog:allow-open",
    "notification:default",
    "shell:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/ncmdump",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
